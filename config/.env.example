# ============================================================
# Bristol OS — Power Layer keys
# Copy this file to ".env" (same folder), fill in what you have,
# then run:  bash config/setup.sh
# Leave a key BLANK to skip that server — setup.sh only wires up
# servers whose key + runtime are present. Nothing breaks if blank.
# ============================================================

# ---------- FREE, NO KEY ----------
# OpenStreetMap (server: osm)  -> geocoding / commute / walkability. No key.
# SEC EDGAR (server: sec-edgar) -> filings + entity research. No key, but SEC
#   REQUIRES you identify yourself. Put your real name + email below.
SEC_EDGAR_USER_AGENT="Bristol Development Group (yeager@bristoldevelopment.com)"

# ---------- FREE KEYS ----------
# FRED — Federal Reserve economic data (rates, CPI, housing starts)
# Get: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage — markets / rates / economic indicators
# Get: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ---------- FREE TIER (sign up; paid only for heavy use) ----------
# Tavily — deep, cited web research
# Get: https://app.tavily.com/home
TAVILY_API_KEY=

# Exa — neural web search
# Get: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Firecrawl — scrape/crawl broker sites, city permit & planning portals
# Get: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# ---------- PAID (Google Cloud billing; has a free monthly credit) ----------
# Google Maps — geocode site addresses, drive-times, nearby places
# Before use: in Google Cloud Console enable "Places API (New)" + "Routes API"
# Get: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=
